<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Upload Video — ImpactGrid Creator Engine</title>
  <link rel="stylesheet" href="style.css"/>
  <style>
    .output-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:18px; transition:border-color 0.2s,transform 0.2s; }
    .output-card:hover { border-color:var(--orange); transform:translateY(-2px); }
    .output-type { font-size:0.59rem; text-transform:uppercase; letter-spacing:1.5px; color:var(--orange); font-weight:700; margin-bottom:6px; }
    .output-card h4 { font-family:'Syne',sans-serif; font-size:0.88rem; font-weight:700; margin-bottom:5px; }
    .output-card p { font-size:0.75rem; color:var(--white-dim); line-height:1.5; }
    .output-foot { display:flex; justify-content:space-between; align-items:center; margin-top:12px; padding-top:10px; border-top:1px solid var(--border); }
    .dl-btn { background:var(--orange); color:white; border:none; padding:5px 11px; border-radius:6px; font-size:0.7rem; font-weight:700; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background 0.15s; }
    .dl-btn:hover { background:var(--orange-dim); }

    /* Processing steps */
    .step-row { display:flex; align-items:center; gap:12px; padding:11px 0; border-bottom:1px solid var(--border); }
    .step-row:last-child { border-bottom:none; }
    .step-ico { width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.9rem; flex-shrink:0; }
    .step-ico.idle   { background:var(--border); }
    .step-ico.active { background:rgba(255,92,26,0.15); animation:stepPulse 1s infinite; }
    .step-ico.done   { background:rgba(31,217,122,0.15); }
    @keyframes stepPulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .step-text h4 { font-size:0.82rem; font-weight:600; margin-bottom:1px; }
    .step-text p  { font-size:0.7rem; color:var(--white-dim); }

    .spec-row { display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--border); font-size:0.8rem; }
    .spec-row:last-child { border-bottom:none; }
    .spec-val { color:var(--green); font-weight:600; font-size:0.76rem; }

    /* State panels */
    #stateIdle    { display:block; }
    #stateProcess { display:none; }
    #stateDone    { display:none; }
  </style>
</head>
<body>
<aside class="sidebar" id="sidebar"></aside>
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger" onclick="openNav()">☰</button>
      <span class="topbar-page-title">Upload Video</span>
    </div>
    <div class="topbar-right">
      <a href="https://impactgridanalytics.com/" target="_blank" class="btn btn-ghost btn-sm" style="border-color:rgba(74,143,245,0.3);color:var(--blue)">📊 Analytics</a>
    </div>
  </div>

  <div class="page-hero">
    <div class="eyebrow">AI Content Engine</div>
    <h1 class="hero-title">Turn raw footage into<br><em>professional content</em></h1>
    <p class="hero-desc">Upload any video from your business. Our AI edits it, captions it, adapts it for every platform, and builds your content calendar — all in minutes.</p>
  </div>

  <section class="section fade-up">
    <div style="display:grid;grid-template-columns:1fr 300px;gap:22px;align-items:start" id="uploadGrid">

      <!-- LEFT COLUMN: changes state -->
      <div>

        <!-- STATE: IDLE — show upload zone -->
        <div id="stateIdle">
          <p class="section-label" style="margin-bottom:14px">Drop Your Video</p>
          <label class="upload-zone" for="videoFile">
            <div style="font-size:3rem">🎬</div>
            <h3>Drop your video here or click to browse</h3>
            <p style="margin-top:6px">MP4, MOV, AVI, MKV — up to 2GB per upload</p>
            <p style="margin-top:4px;font-size:0.7rem;color:#444">Reels · TikToks · Shorts · LinkedIn · Twitter/X · Carousels · Captions — all included</p>
            <input type="file" id="videoFile" accept="video/*" onchange="startUpload(this)"/>
          </label>
        </div>

        <!-- STATE: PROCESSING -->
        <div id="stateProcess">
          <p class="section-label" style="margin-bottom:14px">Processing Your Video</p>
          <div class="card" style="padding:22px">
            <div id="stepRows"></div>
            <div style="margin-top:16px">
              <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:var(--white-dim);margin-bottom:6px">
                <span>Overall progress</span><span id="pctLabel">0%</span>
              </div>
              <div class="progress"><div class="progress-fill" id="progressBar" style="width:0%;transition:width 0.5s ease"></div></div>
            </div>
          </div>
        </div>

        <!-- STATE: DONE — show output cards -->
        <div id="stateDone">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px">
            <div>
              <p class="section-label" style="margin-bottom:2px">Content Ready</p>
              <h3 style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;color:var(--green)">✅ 6 pieces generated</h3>
            </div>
            <button class="btn btn-secondary btn-sm" onclick="resetUpload()">+ Upload Another</button>
          </div>
          <div class="grid-auto">
            <div class="output-card"><div class="output-type">Instagram Reel</div><h4>Behind the scenes 🔥</h4><p>30s vertical cut, trending audio matched, captions burned in. Caption + 15 hashtags.</p><div class="output-foot"><span class="tag">Instagram</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">TikTok</div><h4>Why we do what we do</h4><p>60s story with trend-matched hook, subtitle overlay, voiceover script generated.</p><div class="output-foot"><span class="tag">TikTok</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">LinkedIn Post</div><h4>What building a business really looks like</h4><p>Long-form post with storytelling hook, extracted insights, and engagement CTA.</p><div class="output-foot"><span class="tag">LinkedIn</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">Twitter / X Thread</div><h4>7 things I've learned</h4><p>10-tweet thread with hook, value tweets, CTA — from your video transcript.</p><div class="output-foot"><span class="tag">Twitter/X</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">YouTube Short</div><h4>Quick tip from our shoot ⚡</h4><p>Optimised thumbnail, title, description and tags auto-generated.</p><div class="output-foot"><span class="tag">YouTube</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">Instagram Carousel</div><h4>5 reasons to choose us [Swipe →]</h4><p>6-slide carousel design brief with copy, visual direction, and CTA slide.</p><div class="output-foot"><span class="tag">Instagram</span><button class="dl-btn">↓ Download</button></div></div>
          </div>
          <div style="margin-top:18px;display:flex;gap:10px;flex-wrap:wrap">
            <a href="calendar.html" class="btn btn-primary">View Content Calendar →</a>
          </div>
        </div>

      </div><!-- /left -->

      <!-- RIGHT COLUMN: always visible -->
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="card" style="padding:20px">
          <p class="section-label" style="margin-bottom:12px">What You'll Receive</p>
          <div class="spec-row"><span>Instagram Reels</span><span class="spec-val">✓ 2 cuts</span></div>
          <div class="spec-row"><span>TikTok videos</span><span class="spec-val">✓ 2 cuts</span></div>
          <div class="spec-row"><span>YouTube Shorts</span><span class="spec-val">✓ 1 cut</span></div>
          <div class="spec-row"><span>LinkedIn post</span><span class="spec-val">✓ Full copy</span></div>
          <div class="spec-row"><span>Twitter/X thread</span><span class="spec-val">✓ 10 tweets</span></div>
          <div class="spec-row"><span>Carousel brief</span><span class="spec-val">✓ 6 slides</span></div>
          <div class="spec-row"><span>Captions &amp; hashtags</span><span class="spec-val">✓ All posts</span></div>
          <div class="spec-row"><span>Calendar update</span><span class="spec-val">✓ Auto</span></div>
        </div>
        <div class="card" style="padding:20px">
          <p class="section-label" style="margin-bottom:10px">Tips for Best Results</p>
          <div style="font-size:0.77rem;color:var(--white-dim);line-height:1.7">
            <p>💡 Film in good natural light</p>
            <p style="margin-top:6px">🎙️ Clear audio for auto-captions</p>
            <p style="margin-top:6px">📐 Vertical (9:16) works best</p>
            <p style="margin-top:6px">⏱️ 2–10 minutes ideal length</p>
            <p style="margin-top:6px">🔄 Upload weekly to stay full</p>
          </div>
        </div>
      </div><!-- /right -->

    </div><!-- /grid -->
  </section>

  <footer class="site-footer">
    <div class="footer-brand"><div class="brand">ImpactGrid <em>Creator Engine</em></div><p>AI Content Platform</p></div>
    <div class="footer-links">
      <a href="index.html">Dashboard</a><a href="calendar.html">Calendar</a>
      <a href="creators.html">Book a Creator</a><a href="contact.html">Contact</a>
      <a href="https://impactgridanalytics.com/" target="_blank" class="link-blue">Analytics ↗</a>
    </div>
    <p class="footer-copy">© 2025 ImpactGrid Creator Engine. All rights reserved.</p>
  </footer>
</div>

<script src="nav.js"></script>
<script>
  initNav('upload.html');

  // Responsive grid
  function checkGrid() {
    const g = document.getElementById('uploadGrid');
    if (g) g.style.gridTemplateColumns = window.innerWidth < 760 ? '1fr' : '1fr 300px';
  }
  checkGrid();
  window.addEventListener('resize', checkGrid);

  const stepDefs = [
    { icon:'📥', label:'Receive video',     desc:'Uploading your file…' },
    { icon:'🔍', label:'Analyse content',   desc:'AI scanning your footage…' },
    { icon:'✂️', label:'Edit & trim',       desc:'Creating platform-specific cuts…' },
    { icon:'💬', label:'Generate captions', desc:'Auto-captioning all formats…' },
    { icon:'📝', label:'Write copy',        desc:'Generating posts, threads & hooks…' },
    { icon:'📅', label:'Update calendar',   desc:'Scheduling your content…' },
  ];

  function renderSteps(activeIdx) {
    document.getElementById('stepRows').innerHTML = stepDefs.map((s, i) => {
      const cls = i < activeIdx ? 'done' : i === activeIdx ? 'active' : 'idle';
      const ico = i < activeIdx ? '✅' : s.icon;
      const desc = i <= activeIdx ? s.desc : 'Waiting…';
      return `<div class="step-row">
        <div class="step-ico ${cls}">${ico}</div>
        <div class="step-text"><h4>${s.label}</h4><p>${desc}</p></div>
      </div>`;
    }).join('');
  }

  function startUpload(input) {
    if (!input.files.length) return;
    // Switch to processing state
    document.getElementById('stateIdle').style.display = 'none';
    document.getElementById('stateProcess').style.display = 'block';

    let step = 0;
    const bar = document.getElementById('progressBar');
    const pct = document.getElementById('pctLabel');

    renderSteps(0);

    const timer = setInterval(() => {
      step++;
      const percent = Math.round((step / stepDefs.length) * 100);
      bar.style.width = percent + '%';
      pct.textContent = percent + '%';
      renderSteps(step);

      if (step >= stepDefs.length) {
        clearInterval(timer);
        setTimeout(() => {
          document.getElementById('stateProcess').style.display = 'none';
          document.getElementById('stateDone').style.display = 'block';
        }, 500);
      }
    }, 700);
  }

  function resetUpload() {
    document.getElementById('stateDone').style.display = 'none';
    document.getElementById('stateIdle').style.display = 'block';
    document.getElementById('progressBar').style.width = '0%';
  }
</script>
</body>
</html>
