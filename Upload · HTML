<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Upload Video — ImpactGrid Group</title>
  <meta name="description" content="Upload your business video and get 30+ pieces of professional content across every platform, with captions, edits, and hashtags included."/>
  <link rel="stylesheet" href="style.css"/>
  <style>
    .output-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:18px; transition:border-color 0.2s,transform 0.2s; }
    .output-card:hover { border-color:var(--orange); transform:translateY(-2px); }
    .output-type { font-size:0.6rem; text-transform:uppercase; letter-spacing:1.5px; color:var(--orange); font-weight:700; margin-bottom:6px; }
    .output-card h4 { font-family:'Syne',sans-serif; font-size:0.9rem; font-weight:700; margin-bottom:6px; }
    .output-card p { font-size:0.76rem; color:var(--white-dim); line-height:1.5; }
    .output-foot { display:flex; justify-content:space-between; align-items:center; margin-top:12px; padding-top:10px; border-top:1px solid var(--border); }
    .dl-btn { background:var(--orange); color:white; border:none; padding:5px 11px; border-radius:6px; font-size:0.7rem; font-weight:700; cursor:pointer; font-family:'DM Sans',sans-serif; }
    .progress-step { display:flex; align-items:center; gap:12px; padding:14px 0; border-bottom:1px solid var(--border); }
    .progress-step:last-child { border-bottom:none; }
    .step-icon { width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
    .step-icon.done { background:rgba(31,217,122,0.15); }
    .step-icon.active { background:rgba(255,92,26,0.15); animation:stepPulse 1.2s infinite; }
    .step-icon.waiting { background:var(--card); border:1px solid var(--border); }
    @keyframes stepPulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
    .step-info h4 { font-size:0.85rem; font-weight:600; margin-bottom:2px; }
    .step-info p { font-size:0.72rem; color:var(--white-dim); }
    .spec-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--border); font-size:0.82rem; }
    .spec-row:last-child { border-bottom:none; }
    .spec-val { color:var(--green); font-weight:600; }
  </style>
</head>
<body>

<aside class="sidebar" id="sidebar"></aside>

<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger" onclick="openNav()">☰</button>
      <span class="topbar-page-title">Upload Video</span>
    </div>
    <div class="topbar-right">
      <a href="https://impactgridanalytics.com/" target="_blank" class="btn btn-ghost btn-sm" style="border-color:rgba(74,143,245,0.3);color:var(--blue)">📊 Analytics</a>
    </div>
  </div>

  <!-- HERO -->
  <div class="page-hero">
    <div class="eyebrow">AI Content Engine</div>
    <h1 class="hero-title">Turn raw footage into<br><em>professional content</em></h1>
    <p class="hero-desc">Upload any video from your business. Our AI edits it, captions it, adapts it for every platform, and builds your content calendar — all in minutes.</p>
  </div>

  <!-- UPLOAD + PROCESSING -->
  <section class="section fade-up">
    <div style="display:grid;grid-template-columns:1fr 320px;gap:24px;align-items:start" id="uploadLayout">

      <!-- LEFT: Upload Zone -->
      <div>
        <p class="section-label">Drop Your Video</p>
        <h2 class="section-title" style="margin-bottom:16px">Upload to <em>get started</em></h2>

        <label class="upload-zone" for="videoFile" id="uploadZone">
          <div style="font-size:3rem;margin-bottom:4px">🎬</div>
          <h3>Drop your video here or click to browse</h3>
          <p style="margin-top:6px">MP4, MOV, AVI, MKV — up to 2GB per upload</p>
          <p style="margin-top:4px;font-size:0.72rem;color:#555">Supports: Reels · TikToks · YouTube Shorts · LinkedIn · Twitter/X · Carousels</p>
          <input type="file" id="videoFile" accept="video/*" onchange="startUpload(this)"/>
        </label>

        <!-- Output cards — hidden until upload -->
        <div id="outputGrid" style="display:none;margin-top:24px">
          <p class="section-label" style="margin-bottom:12px">Your Generated Content</p>
          <div class="grid-auto">
            <div class="output-card"><div class="output-type">Instagram Reel</div><h4>Behind the scenes 🔥</h4><p>30s vertical cut, trending audio matched, captions burned in. Caption + 15 hashtags.</p><div class="output-foot"><span class="tag">Instagram</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">TikTok</div><h4>Why we do what we do</h4><p>60s story with trend-matched hook, subtitle overlay, voiceover script generated.</p><div class="output-foot"><span class="tag">TikTok</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">LinkedIn Post</div><h4>What building a business really looks like</h4><p>Long-form post with storytelling hook, extracted insights, and engagement CTA.</p><div class="output-foot"><span class="tag">LinkedIn</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">Twitter / X Thread</div><h4>7 things I've learned building this business</h4><p>10-tweet thread with hook, value tweets, CTA — from your video transcript.</p><div class="output-foot"><span class="tag">Twitter/X</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">YouTube Short</div><h4>Quick tip from our shoot ⚡</h4><p>Optimised thumbnail direction, title, description, and tags auto-generated.</p><div class="output-foot"><span class="tag">YouTube</span><button class="dl-btn">↓ Download</button></div></div>
            <div class="output-card"><div class="output-type">Instagram Carousel</div><h4>5 reasons to choose us [Swipe →]</h4><p>6-slide carousel design brief with copy, visual direction, and final CTA slide.</p><div class="output-foot"><span class="tag">Instagram</span><button class="dl-btn">↓ Download</button></div></div>
          </div>
          <div style="margin-top:20px;display:flex;gap:10px;flex-wrap:wrap">
            <a href="calendar.html" class="btn btn-primary">View Content Calendar →</a>
            <button class="btn btn-secondary" onclick="resetUpload()">Upload Another Video</button>
          </div>
        </div>
      </div>

      <!-- RIGHT: Processing Steps -->
      <div>
        <div class="card" style="padding:22px" id="processingPanel">
          <p class="section-label" style="margin-bottom:14px">Processing Pipeline</p>
          <div id="steps">
            <div class="progress-step"><div class="step-icon waiting">📥</div><div class="step-info"><h4>Receive video</h4><p>Waiting for upload</p></div></div>
            <div class="progress-step"><div class="step-icon waiting">🔍</div><div class="step-info"><h4>Analyse content</h4><p>AI scans your footage</p></div></div>
            <div class="progress-step"><div class="step-icon waiting">✂️</div><div class="step-info"><h4>Edit & trim</h4><p>Platform-specific cuts</p></div></div>
            <div class="progress-step"><div class="step-icon waiting">💬</div><div class="step-info"><h4>Generate captions</h4><p>Auto-caption all formats</p></div></div>
            <div class="progress-step"><div class="step-icon waiting">📝</div><div class="step-info"><h4>Write copy</h4><p>Hooks, threads, posts</p></div></div>
            <div class="progress-step"><div class="step-icon waiting">📅</div><div class="step-info"><h4>Update calendar</h4><p>Schedule your content</p></div></div>
          </div>
        </div>

        <div class="card" style="padding:22px;margin-top:14px">
          <p class="section-label" style="margin-bottom:12px">What You'll Receive</p>
          <div class="spec-row"><span>Instagram Reels</span><span class="spec-val">✓ 2 cuts</span></div>
          <div class="spec-row"><span>TikTok videos</span><span class="spec-val">✓ 2 cuts</span></div>
          <div class="spec-row"><span>YouTube Shorts</span><span class="spec-val">✓ 1 cut</span></div>
          <div class="spec-row"><span>LinkedIn post</span><span class="spec-val">✓ Full copy</span></div>
          <div class="spec-row"><span>Twitter/X thread</span><span class="spec-val">✓ 10 tweets</span></div>
          <div class="spec-row"><span>Carousel brief</span><span class="spec-val">✓ 6 slides</span></div>
          <div class="spec-row"><span>Captions &amp; hashtags</span><span class="spec-val">✓ All posts</span></div>
          <div class="spec-row"><span>Calendar update</span><span class="spec-val">✓ Auto</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TIPS -->
  <section class="section fade-up">
    <p class="section-label">Best Results</p>
    <h2 class="section-title">Tips for <em>great footage</em></h2>
    <p class="section-sub">The better the raw material, the better the output. Here's what performs best.</p>
    <div class="grid-3">
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">💡</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Film in good light</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">Natural light near a window or outdoor shots make AI editing far more effective.</p></div>
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">🎙️</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Clear audio matters</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">Our AI transcribes your speech to write captions and copy. Minimal background noise helps.</p></div>
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">📐</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Film vertically</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">9:16 vertical footage is ideal for Reels, TikToks, and Shorts. Landscape also works fine.</p></div>
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">⏱️</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Aim for 2–10 minutes</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">Longer raw footage gives us more to work with for creating multiple unique pieces.</p></div>
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">🏢</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Show your business</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">Film your space, your team, your product in action. Authentic footage always outperforms.</p></div>
      <div class="card" style="padding:20px"><div style="font-size:1.6rem;margin-bottom:10px">🔄</div><h4 style="font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:6px">Upload weekly</h4><p style="font-size:0.78rem;color:var(--white-dim);line-height:1.5">The more you upload, the more content you get. One video per week keeps your calendar full.</p></div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="footer-brand"><div class="brand">ImpactGrid<em>Group</em></div><p>AI Content Engine · Manchester, UK</p></div>
    <div class="footer-links">
      <a href="index.html">Dashboard</a><a href="calendar.html">Calendar</a>
      <a href="creators.html">Book a Creator</a><a href="contact.html">Contact</a>
      <a href="https://impactgridanalytics.com/" target="_blank" class="link-blue">Analytics ↗</a>
    </div>
    <p class="footer-copy">© 2025 ImpactGrid Group. All rights reserved.</p>
  </footer>
</div>

<script src="nav.js"></script>
<script>
  initNav('upload.html');

  // Responsive layout
  function checkLayout() {
    const el = document.getElementById('uploadLayout');
    if (el) el.style.gridTemplateColumns = window.innerWidth < 760 ? '1fr' : '1fr 320px';
  }
  checkLayout();
  window.addEventListener('resize', checkLayout);

  function startUpload(input) {
    if (!input.files.length) return;
    const zone = document.getElementById('uploadZone');
    zone.innerHTML = `<div style="font-size:2.4rem">⚙️</div><h3 style="color:var(--orange);margin-top:8px">Analysing your video…</h3><p style="margin-top:6px">AI is generating content for 7 platforms. Just a moment.</p>`;

    const stepLabels = [
      ['📥','Receive video','Uploading…'],
      ['🔍','Analyse content','Scanning footage…'],
      ['✂️','Edit & trim','Creating platform cuts…'],
      ['💬','Generate captions','Writing captions…'],
      ['📝','Write copy','Generating posts & threads…'],
      ['📅','Update calendar','Scheduling your content…']
    ];

    let step = 0;
    const stepsEl = document.getElementById('steps');

    function updateSteps() {
      stepsEl.innerHTML = stepLabels.map(([icon, title, desc], i) => {
        let cls = i < step ? 'done' : i === step ? 'active' : 'waiting';
        let ico = i < step ? '✅' : icon;
        return `<div class="progress-step"><div class="step-icon ${cls}">${ico}</div><div class="step-info"><h4>${title}</h4><p>${i <= step ? desc : 'Waiting…'}</p></div></div>`;
      }).join('');
    }

    const timer = setInterval(() => {
      updateSteps();
      step++;
      if (step >= stepLabels.length) {
        clearInterval(timer);
        setTimeout(() => {
          zone.innerHTML = `<div style="font-size:2.4rem">✅</div><h3 style="color:var(--green);margin-top:8px">Content ready — 6 pieces generated!</h3><p style="margin-top:4px">Your calendar has been updated automatically.</p>`;
          document.getElementById('outputGrid').style.display = 'block';
          document.getElementById('outputGrid').scrollIntoView({ behavior:'smooth', block:'nearest' });
        }, 500);
      }
    }, 700);
  }

  function resetUpload() {
    document.getElementById('outputGrid').style.display = 'none';
    const zone = document.getElementById('uploadZone');
    zone.innerHTML = `<div style="font-size:3rem;margin-bottom:4px">🎬</div><h3>Drop your video here or click to browse</h3><p style="margin-top:6px">MP4, MOV, AVI, MKV — up to 2GB per upload</p><p style="margin-top:4px;font-size:0.72rem;color:#555">Supports: Reels · TikToks · YouTube Shorts · LinkedIn · Twitter/X · Carousels</p><input type="file" id="videoFile" accept="video/*" onchange="startUpload(this)"/>`;
  }
</script>
</body>
</html>
