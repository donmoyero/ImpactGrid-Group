      <div class="cal-cell filled"><div class="cal-num">22</div><span class="cal-pill reel">Reel</span></div>
      <div class="cal-cell"><div class="cal-num">23</div></div>

      <div class="cal-cell filled"><div class="cal-num">24</div><span class="cal-pill carousel">Carousel</span><span class="cal-pill post">Post</span></div>
      <div class="cal-cell filled"><div class="cal-num">25</div><span class="cal-pill reel">Reel</span></div>
      <div class="cal-cell filled"><div class="cal-num">26</div><span class="cal-pill story">Story</span><span class="cal-pill post">Post</span></div>
      <div class="cal-cell filled"><div class="cal-num">27</div><span class="cal-pill reel">Reel</span><span class="cal-pill carousel">Carousel</span></div>
      <div class="cal-cell filled"><div class="cal-num">28</div><span class="cal-pill story">Story</span></div>
      <div class="cal-cell filled"><div class="cal-num">29</div><span class="cal-pill reel">Reel</span></div>
