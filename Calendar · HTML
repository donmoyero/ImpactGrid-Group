      <div class="cal-cell"><div class="cal-num">16</div></div>

      <div class="cal-cell filled"><div class="cal-num">17</div><span class="cal-pill post">Post</span></div>
      <div class="cal-cell filled"><div class="cal-num">18</div><span class="cal-pill reel">Reel</span><span class="cal-pill story">Story</span></div>
