<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Content Calendar — ImpactGrid Creator Engine</title>
  <link rel="stylesheet" href="style.css"/>
  <style>
    .legend { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:22px; }
    .legend-item { display:flex; align-items:center; gap:5px; font-size:0.72rem; }
    .legend-dot { width:8px; height:8px; border-radius:2px; }
    .month-nav { display:flex; align-items:center; gap:12px; margin-bottom:20px; }
    .month-nav button { background:var(--card); border:1px solid var(--border-lg); color:var(--white); width:32px; height:32px; border-radius:6px; cursor:pointer; font-size:0.9rem; }
    .month-nav h3 { font-family:'Syne',sans-serif; font-size:1.1rem; font-weight:700; }
  </style>
</head>
<body>

<aside class="sidebar" id="sidebar"></aside>

<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger" onclick="openNav()">☰</button>
      <span class="topbar-page-title">Content Calendar</span>
    </div>
    <div class="topbar-right">
      <a href="upload.html" class="btn btn-primary btn-sm">+ Upload Video</a>
    </div>
  </div>

  <div class="page-hero">
    <div class="eyebrow">30-Day Planning</div>
    <h1 class="hero-title">Your <em>Content Calendar</em></h1>
    <p class="hero-desc">Every video you upload auto-populates this calendar with platform-specific content, captions, and optimal posting times. Keep uploading — keep your calendar full.</p>
  </div>

  <section class="section fade-up">
    <div class="legend">
      <div class="legend-item"><div class="legend-dot" style="background:var(--orange)"></div> Reel</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--yellow)"></div> Story</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div> Post</div>
      <div class="legend-item"><div class="legend-dot" style="background:#a0aaff"></div> Carousel</div>
    </div>

    <div class="month-nav">
      <button>‹</button>
      <h3>March 2025</h3>
      <button>›</button>
    </div>

    <div class="cal-grid">
      <div class="cal-header">Mon</div><div class="cal-header">Tue</div><div class="cal-header">Wed</div>
      <div class="cal-header">Thu</div><div class="cal-header">Fri</div><div class="cal-header">Sat</div><div class="cal-header">Sun</div>

      <div class="cal-cell"><div class="cal-num" style="color:#444">24</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">25</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">26</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">27</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">28</div></div>
      <div class="cal-cell filled"><div class="cal-num">1</div><span class="cal-pill reel">Reel</span><span class="cal-pill story">Story</span></div>
      <div class="cal-cell"><div class="cal-num">2</div></div>

      <div class="cal-cell filled"><div class="cal-num">3</div><span class="cal-pill post">Post</span></div>
      <div class="cal-cell filled"><div class="cal-num">4</div><span class="cal-pill carousel">Carousel</span><span class="cal-pill reel">Reel</span></div>
      <div class="cal-cell filled"><div class="cal-num">5</div><span class="cal-pill story">Story</span></div>
      <div class="cal-cell filled"><div class="cal-num">6</div><span class="cal-pill reel">Reel</span><span class="cal-pill post">Post</span></div>
      <div class="cal-cell filled"><div class="cal-num">7</div><span class="cal-pill carousel">Carousel</span></div>
      <div class="cal-cell filled"><div class="cal-num">8</div><span class="cal-pill reel">Reel</span></div>
      <div class="cal-cell"><div class="cal-num">9</div></div>

      <div class="cal-cell filled"><div class="cal-num">10</div><span class="cal-pill post">Post</span><span class="cal-pill story">Story</span></div>
      <div class="cal-cell filled"><div class="cal-num">11</div><span class="cal-pill reel">Reel</span></div>
      <div class="cal-cell filled"><div class="cal-num">12</div><span class="cal-pill carousel">Carousel</span></div>
      <div class="cal-cell filled"><div class="cal-num">13</div><span class="cal-pill reel">Reel</span><span class="cal-pill post">Post</span></div>
