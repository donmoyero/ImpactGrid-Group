      <div class="cal-cell filled"><div class="cal-num">31</div><span class="cal-pill post">Post</span></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">1</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">2</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">3</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">4</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">5</div></div>
      <div class="cal-cell"><div class="cal-num" style="color:#444">6</div></div>
    </div>

    <div style="margin-top:20px;display:flex;gap:10px;flex-wrap:wrap">
      <a href="upload.html" class="btn btn-primary">+ Upload More Videos</a>
      <a href="schedule.html" class="btn btn-secondary">View Posting Schedule</a>
    </div>
  </section>

  <!-- CONTENT STYLES -->
  <section class="section fade-up">
    <p class="section-label">Content Styles</p>
    <h2 class="section-title">Different styles, <em>every day</em></h2>
    <p class="section-sub">We rotate content formats so your audience never gets bored. Here's what we create.</p>
    <div class="grid-auto-sm">
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">🎬</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Behind the Scenes</strong><p style="font-size:0.74rem;color:var(--white-dim)">Raw, authentic footage of your business in action.</p></div>
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">📖</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Story-Led</strong><p style="font-size:0.74rem;color:var(--white-dim)">Emotional narratives that build brand connection.</p></div>
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">💡</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Educational</strong><p style="font-size:0.74rem;color:var(--white-dim)">Tips, how-tos, and expert knowledge from your business.</p></div>
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">🔥</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Trend-Riding</strong><p style="font-size:0.74rem;color:var(--white-dim)">Content matched to current trending formats and sounds.</p></div>
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">👥</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Team Spotlight</strong><p style="font-size:0.74rem;color:var(--white-dim)">Showcase the people behind your brand.</p></div>
      <div class="card" style="padding:18px"><div style="margin-bottom:8px;font-size:1.4rem">🏆</div><strong style="font-family:'Syne',sans-serif;font-size:0.88rem;display:block;margin-bottom:4px">Social Proof</strong><p style="font-size:0.74rem;color:var(--white-dim)">Testimonials, results, and client success stories.</p></div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="footer-brand"><div class="brand">ImpactGrid <em>Creator Engine</em></div><p>AI AI Content Platform</p></div>
    <div class="footer-links">
      <a href="index.html">Dashboard</a><a href="upload.html">Upload</a>
      <a href="schedule.html">Schedule</a><a href="contact.html">Contact</a>
      <a href="https://impactgridanalytics.com/" target="_blank" class="link-blue">Analytics ↗</a>
    </div>
    <p class="footer-copy">© 2025 ImpactGrid Creator Engine. All rights reserved.</p>
  </footer>
</div>

<script src="nav.js"></script>
<script>initNav('calendar.html');</script>
</body>
</html>
