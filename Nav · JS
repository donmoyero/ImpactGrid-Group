function buildSidebar(activePage) {
  const links = [
    { group: 'Platform', items: [
      { href: 'index.html',       icon: 'grid',     label: 'Dashboard' },
      { href: 'upload.html',      icon: 'upload',   label: 'Upload Video', badge: 'NEW' },
      { href: 'calendar.html',    icon: 'calendar', label: 'Content Calendar' },
      { href: 'schedule.html',    icon: 'clock',    label: 'Posting Schedule' },
      { href: 'trending.html',    icon: 'trend',    label: 'Trending Topics' },
    ]},
    { group: 'Services', items: [
      { href: 'creators.html',    icon: 'users',    label: 'Book a Creator' },
      { href: 'tracker.html',     icon: 'locate',   label: 'Live Tracker' },
      { href: 'services.html',    icon: 'star',     label: 'All Services' },
      { href: 'photography.html', icon: 'camera',   label: 'Photography' },
    ]},
    { group: 'Company', items: [
